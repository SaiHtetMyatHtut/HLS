# Copy this file to .env and fill in your Supabase credentials.
# You can find all of these in your Supabase project dashboard.

# API settings (Settings → API)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection (Settings → Database → Connection string → URI)
# Used only by the db:setup / db:seed / db:reset npm scripts
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
